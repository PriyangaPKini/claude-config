{
  "permissions": {
    "allow": [
      "Bash(osascript:*)",
      "Bash(afplay:*)",
      "Bash(git clone --depth 1:*)",
      "Bash(git clone --filter=blob:none --no-checkout:*)",
      "Bash(git -C /tmp/megasthenes-subagent/*:*)",
      "Bash(mkdir -p /tmp/megasthenes-subagent/*)",
      "Bash(ls /tmp/megasthenes-subagent/*)",
      "Read(/tmp/megasthenes-subagent/**)",
      "Grep(/tmp/megasthenes-subagent/**)",
      "Glob(/tmp/megasthenes-subagent/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task complete\" with title \"Claude Code\"' && afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"' && afplay /System/Library/Sounds/Sosumi.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/traces-session-env.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/hooks/display-tokens.sh",
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "developer-plugins": {
      "source": {
        "source": "github",
        "repo": "PriyangaPKini/claude-config"
      }
    }
  },
  "voiceEnabled": true,
  "effortLevel": "medium"
}
